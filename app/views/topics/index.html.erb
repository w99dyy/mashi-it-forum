<% content_for :title, "All Topics" %>

<div class="posts-page min-h-screen">
  <%# Page Header %>

  <div class="mb-2 border-b border-[#2a2a2a] pb-8">
    <h1 class="text-2xl font-bold text-white mb-4 break-words"> Topics </h1>
    <p class="text-gray-400 text-sm "> Browse all posts </p>
    <div class="float-right hidden sm:flex text-gray-400 gap-9">
    <p>Comments</p>
    <p> Posts </p>
    </div>
  </div>

  <%# Topics List %>
  
  <div class="posts-container divide-y divide-[#2a2a2a] overflow-visible">
  <% if @topics.any? %>
    <% @topics.each do |topic| %>

      <div class="topic mt-4">
      <div class="float-right text-gray-400 hidden sm:block">
      <div class="flex items-center">
        <div class="min-w-[2.5rem] text-center tabular-nums">
          <span class="block"><%= topic.posts_count.to_i %> </span>
        </div>
        <div class="min-w-[6rem] text-right tabular-nums">
          <span class="block"><%= topic.posts.sum { |p| p.comments_count.to_i } %></span>
        </div>
      </div>
    </div>

        <div class="flex items-center flex-wrap">
        <h2>
        <%= link_to topic.title, topic_posts_path(topic), class: "hover:text-[#ababab] transition font-bold" %>
          <span>
        <% if topic.pinned? %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pinned inline-block align-middle" style="color: green"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 3a1 1 0 0 1 .117 1.993l-.117 .007v4.764l1.894 3.789a1 1 0 0 1 .1 .331l.006 .116v2a1 1 0 0 1 -.883 .993l-.117 .007h-4v4a1 1 0 0 1 -1.993 .117l-.007 -.117v-4h-4a1 1 0 0 1 -.993 -.883l-.007 -.117v-2a1 1 0 0 1 .06 -.34l.046 -.107l1.894 -3.791v-4.762a1 1 0 0 1 -.117 -1.993l.117 -.007h8z" /></svg>
        <% end %>
        <% if topic.locked? %>
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-lock inline-block align-middle" style="color: gray"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 2a5 5 0 0 1 5 5v3a3 3 0 0 1 3 3v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-6a3 3 0 0 1 3 -3v-3a5 5 0 0 1 5 -5m0 12a2 2 0 0 0 -1.995 1.85l-.005 .15a2 2 0 1 0 2 -2m0 -10a3 3 0 0 0 -3 3v3h6v-3a3 3 0 0 0 -3 -3" /></svg>
        <% end %>
        </span>
        </h2>
        </div>
        <%# Tags %>

      <% if topic.tags.any? %>
        <div class="tags mb-4 mt-2">
          <div class="flex flex-wrap gap-2">
            <% topic.tags.each do |tag| %>
            <%= link_to tag.name, topics_path(tag: tag.name),
            class: "bg-[#de7200] text-white px-4 rounded-full text-sm hover:bg-[#df8322]" %>

            <% end %>
          </div>
        </div>
      <% end %>
      
      </div>

    <% end %>

    <% else %>
    <div class="empty-state text-center py-16 rounded-lg">
        <h3 class="text-2xl font-bold text-white mb-2">No topics yet</h3>
        <p class="text-gray-400 mb-6">Wait for an admin create one.</p>
        
      </div>

    <% end %>
      
  </div>
</div>
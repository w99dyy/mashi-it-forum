<!-- Avatar — rendered from DB, visible to everyone -->
      <div class="w-12 h-12 rounded-full overflow-hidden border-4 border-blue-500 bg-gray-100">
      <div class="relative w-full h-full">
  <% if user.mashit_layers.any? %>
    <% user.mashit_layers.each do |layer| %>
      <img src="<%= layer['image'] %>"
           alt="<%= layer['name'] %>"
           class="absolute inset-0 w-full h-full object-cover">
    <% end %>
  <% else %>
    <img src="<%= asset_path('mashit.png') %>"
         alt="Default avatar"
         class="w-full h-full object-cover">
  <% end %>
</div>
      </div>
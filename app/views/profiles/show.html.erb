<% content_for :title, @user.username %>

<div class=" mx-auto px-4 py-8">
  <div class="rounded-lg shadow-lg p-6 mb-6">
    <div class="flex items-start space-x-6">

      <!-- Avatar — full card -->
      <div class="rounded-lg overflow-hidden relative" style="width: 276px; height: 368px;">
      <% if @user.mashit_layers.any? %>
      <% @user.mashit_layers.each do |layer| %>
        <% if layer['name'] == 'background' %>
          <img src="<%= layer['image'] %>"
              alt="<%= layer['name'] %>"
              class="absolute inset-0 w-full h-full object-cover">
        <% else %>
          <img src="<%= layer['image'] %>"
              alt="<%= layer['name'] %>"
              class="absolute inset-0 w-full h-full object-contain">
        <% end %>
      <% end %>
      <% else %>
        <img src="<%= asset_path('mashit.png') %>"
            alt="Default avatar"
            class="rounded-lg object-contain">
      <% end %>
      </div>

      <!-- User Info -->
      <div class="hidden sm:block">
      <div class="flex justify-between items-center gap-2">
        <h1 class="text-2xl font-bold"><%= @user.username %></h1>
        <% if user_has_badges?(@user, "Developer") %>
       <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-code-circle-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M17 3.34a10 10 0 1 1 -15 8.66l.005 -.324a10 10 0 0 1 14.995 -8.336m-3.658 5.22a1 1 0 0 0 -1.282 .598l-2 5.5a1 1 0 0 0 1.88 .684l2 -5.5a1 1 0 0 0 -.598 -1.282m-4.135 1.233a1 1 0 0 0 -1.414 0l-1.5 1.5a1 1 0 0 0 0 1.414l1.5 1.5a1 1 0 0 0 1.414 0l.083 -.094a1 1 0 0 0 -.083 -1.32l-.792 -.793l.792 -.793a1 1 0 0 0 0 -1.414m7 0a1 1 0 0 0 -1.414 0l-.083 .094a1 1 0 0 0 .083 1.32l.792 .793l-.792 .793a1 1 0 0 0 1.414 1.414l1.5 -1.5a1 1 0 0 0 0 -1.414z" /></svg>
        <% end %>
        <% if user_has_badges?(@user, "Admin") %>
        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-shield-checkered"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11.013 12v9.754a13 13 0 0 1 -8.733 -9.754h8.734zm9.284 3.794a13 13 0 0 1 -7.283 5.951l-.001 -9.745h8.708a12.96 12.96 0 0 1 -1.424 3.794zm-9.283 -13.268l-.001 7.474h-8.986c-.068 -1.432 .101 -2.88 .514 -4.282a1 1 0 0 1 1.005 -.717a11 11 0 0 0 7.192 -2.256l.276 -.219zm1.999 7.474v-7.453l-.09 -.073a11 11 0 0 0 7.189 2.537l.342 -.01a1 1 0 0 1 1.005 .717c.413 1.403 .582 2.85 .514 4.282h-8.96z" /></svg>
        <% end %> 
        </div>
        <% if @user.badges.any? %>
          <ul>
          <% @user.badges.each do |badge| %>
            <li><%= badge.name %></li>
          <% end %>
        </ul>
        <% end %>
        <% if current_user == @user %>
        <p class="text-gray-600 mb-4"><%= @user.email %></p>
        <% end %>

        <!-- Wallet section — only shown to profile owner -->
        <% if current_user == @user %>
          <div data-controller="wallet">
            <div class="rounded-lg" >
              <div>
                <p class="font-medium">Wallet Status</p>
                <% if @user.wallet_connected? %>
                  <p class="text-sm text-green-600">Connected</p>
                  <p class="text-sm text-gray-500 font-mono">
                    <%= "#{@user.wallet_address.first(6)}...#{@user.wallet_address.last(4)}" %>
                  </p>
                <% else %>
                  <p class="text-sm text-gray-500">Not connected</p>
                <% end %>
              </div>

              <button data-wallet-target="button"
                      data-action="click->wallet#toggle"
                      class="px-6 py-2 mt-3 rounded-lg text-white transition
                             <%= @user.wallet_connected? ? 'bg-red-600 hover:bg-red-700' : 'bg-[#ed5024] hover:bg-[#e0603c]' %>">
                <%= @user.wallet_connected? ? 'Disconnect Wallet' : 'Connect Wallet' %>
              </button>
            </div>
          </div>
        <% end %>

      </div>

      </div>
       <!-- Mobile user Info -->
      <div class="block sm:hidden text-center">
        <div class="flex justify-center items-center gap-2">
        <h1 class="text-2xl font-bold"><%= @user.username %></h1>
        <% if user_has_badges?(@user, "Developer") %>
       <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-code-circle-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M17 3.34a10 10 0 1 1 -15 8.66l.005 -.324a10 10 0 0 1 14.995 -8.336m-3.658 5.22a1 1 0 0 0 -1.282 .598l-2 5.5a1 1 0 0 0 1.88 .684l2 -5.5a1 1 0 0 0 -.598 -1.282m-4.135 1.233a1 1 0 0 0 -1.414 0l-1.5 1.5a1 1 0 0 0 0 1.414l1.5 1.5a1 1 0 0 0 1.414 0l.083 -.094a1 1 0 0 0 -.083 -1.32l-.792 -.793l.792 -.793a1 1 0 0 0 0 -1.414m7 0a1 1 0 0 0 -1.414 0l-.083 .094a1 1 0 0 0 .083 1.32l.792 .793l-.792 .793a1 1 0 0 0 1.414 1.414l1.5 -1.5a1 1 0 0 0 0 -1.414z" /></svg>
        <% end %>
        <% if user_has_badges?(@user, "Admin") %>
        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-shield-checkered"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11.013 12v9.754a13 13 0 0 1 -8.733 -9.754h8.734zm9.284 3.794a13 13 0 0 1 -7.283 5.951l-.001 -9.745h8.708a12.96 12.96 0 0 1 -1.424 3.794zm-9.283 -13.268l-.001 7.474h-8.986c-.068 -1.432 .101 -2.88 .514 -4.282a1 1 0 0 1 1.005 -.717a11 11 0 0 0 7.192 -2.256l.276 -.219zm1.999 7.474v-7.453l-.09 -.073a11 11 0 0 0 7.189 2.537l.342 -.01a1 1 0 0 1 1.005 .717c.413 1.403 .582 2.85 .514 4.282h-8.96z" /></svg>
        <% end %> 
        </div>
        <% if @user.badges.any? %>
          <ul>
          <% @user.badges.each do |badge| %>
            <li><%= badge.name %></li>
          <% end %>
        </ul>
        <% end %>
        <% if current_user == @user %>
        <p class="text-gray-600 mb-4"><%= @user.email %></p>
        <% end %>

        <!-- Wallet section — only shown to profile owner -->
        <% if current_user == @user %>
          <div data-controller="wallet">
            <div class="rounded-lg" >
              <div>
                <p class="font-medium">Wallet Status</p>
                <% if @user.wallet_connected? %>
                  <p class="text-sm text-green-600">Connected</p>
                  <p class="text-sm text-gray-500 font-mono">
                    <%= "#{@user.wallet_address.first(6)}...#{@user.wallet_address.last(4)}" %>
                  </p>
                <% else %>
                  <p class="text-sm text-gray-500">Not connected</p>
                <% end %>
              </div>

              <button data-wallet-target="button"
                      data-action="click->wallet#toggle"
                      class="px-6 py-2 mt-3 rounded-lg text-white transition
                             <%= @user.wallet_connected? ? 'bg-red-600 hover:bg-red-700' : 'bg-[#ed5024] hover:bg-[#e0603c]' %>">
                <%= @user.wallet_connected? ? 'Disconnect Wallet' : 'Connect Wallet' %>
              </button>
            </div>
          </div>
        <% end %>
    </div>
  </div>
  
<div class=" divide-y divide-[#2a2a2a]">

<% if @user.posts.any? %>
  <% @user.posts.each do |post| %>
    <div class="post-card p-6 pb-8 " >

    <%# if post.thumbnail %>
              <%# link_to image_tag(post.thumbnail.representation(resize_to_limit: [120, 120])), topic_post_path(post.topic, post), class: "float-left pr-5" %>
            <%# end %>

      <!-- Post Title -->
      <h2 class="text-lg font-bold text-white mb-3 ">
       <%= link_to truncate(post.title, length: 150), topic_post_path(post.topic, post), class: "hover:text-[#ababab] transition" %>

      </h2>

      <!-- Tags -->
      <% if post.tags.any? %>
        <div class="tags mb-4">
          <div class="flex flex-wrap gap-2">
            <% post.tags.each do |tag| %>
            <div class="bg-[#de7200] text-white px-3 py-1 rounded-full text-sm">
             <%= tag.name %>
            </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <!-- Post Metadata -->
        <div>
          <div class="flex text-sm text-gray-400 flex-wrap gap-2">
              <span>Posted <%= time_ago_in_words(post.updated_at) %> ago</span>
              <% if post.updated_at.present? && post.updated_at > post.created_at + 1.minute %>
              <div class="flex flex-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pencil"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12.085 6.5l5.415 5.415l-8.793 8.792a1 1 0 0 1 -.707 .293h-4a1 1 0 0 1 -1 -1v-4a1 1 0 0 1 .293 -.707zm5.406 -2.698a3.828 3.828 0 0 1 1.716 6.405l-.292 .293l-5.415 -5.415l.293 -.292a3.83 3.83 0 0 1 3.698 -.991" />
                <span> <%= time_ago_in_words(post.updated_at) %> ago</span>
                </svg>
                </div>
              <% end %>
        </div>
        
      </div>
    </div>
  <% end %>
<% else %>

  <!-- Empty State -->
  <div class="empty-state text-center py-16 rounded-lg w-full max-w-full">
    <div class="text-6xl mb-4">📝</div>
    <h3 class="text-2xl font-bold text-white mb-5 ">You didn't post yet.</h3>
<% end %>
</div>

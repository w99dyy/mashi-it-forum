<% content_for :title, @user.username %>

<div class=" mx-auto px-4 py-8">
  <div class="rounded-lg shadow-lg p-6 mb-6">
    <div class="flex items-start space-x-6">

      <!-- Avatar — full card -->
      <div class="rounded-lg overflow-hidden relative" style="width: 276px; height: 368px;">
      <% if @user.mashit_layers.any? %>
      <% @user.mashit_layers.each do |layer| %>
        <% if layer['name'] == 'background' %>
          <img src="<%= layer['image'] %>"
              alt="<%= layer['name'] %>"
              class="absolute inset-0 w-full h-full object-cover">
        <% else %>
          <img src="<%= layer['image'] %>"
              alt="<%= layer['name'] %>"
              class="absolute inset-0 w-full h-full object-contain">
        <% end %>
      <% end %>
      <% else %>
        <img src="<%= asset_path('mashit.png') %>"
            alt="Default avatar"
            class="rounded-lg object-contain">
      <% end %>
      </div>

      <!-- User Info -->
      <div class="hidden sm:block">
        <h1 class="text-2xl font-bold"><%= @user.username %></h1>

        <% if current_user == @user %>
        <p class="text-gray-600 mb-4"><%= @user.email %></p>
        <% end %>

        <!-- Wallet section — only shown to profile owner -->
        <% if current_user == @user %>
          <div data-controller="wallet">
            <div class=" p-4 rounded-lg >
              <div>
                <p class="font-medium">Wallet Status</p>
                <% if @user.wallet_connected? %>
                  <p class="text-sm text-green-600">Connected</p>
                  <p class="text-sm text-gray-500 font-mono">
                    <%= "#{@user.wallet_address.first(6)}...#{@user.wallet_address.last(4)}" %>
                  </p>
                <% else %>
                  <p class="text-sm text-gray-500">Not connected</p>
                <% end %>
              </div>

              <button data-wallet-target="button"
                      data-action="click->wallet#toggle"
                      class="px-6 py-2 rounded-lg text-white transition
                             <%= @user.wallet_connected? ? 'bg-red-600 hover:bg-red-700' : 'bg-[#ed5024] hover:bg-[#e0603c]' %>">
                <%= @user.wallet_connected? ? 'Disconnect Wallet' : 'Connect Wallet' %>
              </button>
            </div>
          </div>
        <% end %>

      </div>

       <!-- User Info -->
      <div class="block sm:hidden text-center pt-4">
        <h1 class="text-2xl font-bold"><%= @user.username %></h1>

        <% if current_user == @user %>
        <p class="text-gray-600 mb-4"><%= @user.email %></p>
        <% end %>

        <!-- Wallet section — only shown to profile owner -->
        <% if current_user == @user %>
          <div data-controller="wallet">
            <div class=" p-4 rounded-lg >
              <div>
                <p class="font-medium">Wallet Status</p>
                <% if @user.wallet_connected? %>
                  <p class="text-sm text-green-600">Connected</p>
                  <p class="text-sm text-gray-500 font-mono">
                    <%= "#{@user.wallet_address.first(6)}...#{@user.wallet_address.last(4)}" %>
                  </p>
                <% else %>
                  <p class="text-sm text-gray-500">Not connected</p>
                <% end %>
              </div>

              <button data-wallet-target="button"
                      data-action="click->wallet#toggle"
                      class="px-6 py-2 rounded-lg text-white transition
                             <%= @user.wallet_connected? ? 'bg-red-600 hover:bg-red-700' : 'bg-[#ed5024] hover:bg-[#e0603c]' %>">
                <%= @user.wallet_connected? ? 'Disconnect Wallet' : 'Connect Wallet' %>
              </button>
            </div>
          </div>
        <% end %>

      </div>
     

    </div>

  </div>


<div class=" divide-y divide-[#2a2a2a]">

<% if @user.posts.any? %>
  <% @user.posts.each do |post| %>
    <div class="post-card p-6 pb-8 " >

    <% if post.thumbnail %>
              <%= link_to image_tag(post.thumbnail.representation(resize_to_limit: [120, 120])), topic_post_path(post.topic, post), class: "float-left pr-5" %>
            <% end %>

      <!-- Post Title -->

      <h2 class="text-lg font-bold text-white mb-3 ">
       <%= link_to truncate(post.title, length: 150), topic_post_path(post.topic, post), class: "hover:text-[#ababab] transition" %>

      </h2>
      
      <!-- Post Content Preview -->

     
     
      
      <!-- Tags -->

      <% if post.tags.any? %>
        <div class="tags mb-4">
          <div class="flex flex-wrap gap-2">
            <% post.tags.each do |tag| %>
            <div class="bg-[#de7200] text-white px-3 py-1 rounded-full text-sm">
             <%= tag.name %>
            </div>
            <% end %>
          </div>
        </div>
      <% end %>
      
      <!-- Post Metadata -->
          
          <div class="flex justify-between text-sm text-gray-400 ">
            <div>
              <span class="mr-4">
              Posted <%= time_ago_in_words(post.updated_at) %> ago</span>
              <% if post.updated_at.present? && post.updated_at > post.created_at + 1.minute %>
                <span>Edited <%= time_ago_in_words(post.updated_at) %> ago</span>
              <% end %>
            </div>
        
      </div>
    </div>
  <% end %>
<% else %>

  <!-- Empty State -->
  
  <div class="empty-state text-center py-16 rounded-lg w-full max-w-full">
    <div class="text-6xl mb-4">📝</div>
    <h3 class="text-2xl font-bold text-white mb-5 ">You didn't post yet.</h3>
<% end %>
  
</div>

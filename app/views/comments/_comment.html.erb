  <%= turbo_frame_tag dom_id(comment) do %>
  <div class="border-b border-[#2a2a2a] ml-auto">
        <!-- three dots -->
        <% if user_signed_in? && (current_user.admin? || current_user == @post.user) %>
          <div class="float-right">
              <button class="peer hover:text-[#ababab] rounded-full outline-none ml-3 ">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-three-dots " viewBox="0 0 16 16">
          <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/>
        </svg>
        </button>

          <div class="peer absolute text-sm mt-2 opacity-0 invisible peer-focus:opacity-100 peer-focus:visible transition-all duration-200 rounded-lg shadow-[0_20px_40px_-1px_rgba(0,0,0,0.3)] w-48 z-10">
          
            <%= link_to "Edit", edit_topic_post_comment_path(comment.post.topic,
             comment.post, comment), 
             class: "block w-full text-left px-4 py-2 text-sm hover:bg-red-50 dark:hover:bg-red-900/20 text-white " %>

            <%= button_to "Delete", 
            topic_post_comment_path(comment.post.topic, comment.post, comment),
             method: :delete,
              class: "block w-full text-left px-4 py-2 text-sm hover:bg-red-50 dark:hover:bg-red-900/20 text-red-600 dark:text-red-400" %>
          </div>

        </div>
        <% end %>

        <div class="float-left flex pr-3 pt-3">
          <%= link_to render('avatar_pfp/mashit_avatar_comments', user: comment.user), profile_path(comment.user.username) %>
        </div>
       <%= comment.user.username %>
      <div class="py-8 overflow-hidden">
        <%= comment.body.to_s.html_safe %>
      </div>

      </div>
  <% end %>
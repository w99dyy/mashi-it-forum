  <div id="reply_form_wrapper_<%= comment.id %>">
    <%= turbo_frame_tag "reply_form_#{comment.id}" do %>
      <%= form_with(model: [@topic, @post, Comment.new(parent_id: comment.id)]) do |form| %>
      
      <% if comment.parent.present? %>
        <div class="quote-block flex items-center pb-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" style="transform: scaleX(-1);" class="text-gray-400" viewBox="0 0 16 16">
              <path d="M5.921 11.9 1.353 8.62a.72.72 0 0 1 0-1.238L5.921 4.1A.716.716 0 0 1 7 4.719V6c1.5 0 6 0 7 8-2.5-4.5-7-4-7-4v1.281c0 .56-.606.898-1.079.62z"/>
            </svg>
            
            <div class="flex items-center gap-1">
              <%= link_to render('avatar_pfp/mashit_avatar_comments', user: comment.parent.user), profile_path(comment.parent.user.username), data: { turbo: false }, class: "inline-block pl-2" %>
              <%= link_to comment.parent.user.username, profile_path(comment.parent.user.username), data: { turbo: false }, class: "text-[#ed5024] text-sm hover:underline pr-5" %>
            </div>
          <blockquote><%# comment.parent.body %></blockquote>
        </div>
      <% end %>

        <%= form.hidden_field :parent_id, value: comment.id %>
        <%= form.rich_text_area :body, id: "reply_body_#{comment.id}" %>
        
        <div class="flex gap-2 items-center mt-2 mb-3">
          <%= form.submit "Reply", class: "bg-[#ed5024] hover:bg-[#e0603c] py-1 px-8 pr-5 pl-5 font-medium rounded-full shadow transition duration-200 cursor-pointer" %>
          
          <button type="button" 
                  onclick="document.getElementById('reply_form_container_<%= comment.id %>').style.display='none'; document.getElementById('reply_button_<%= comment.id %>').style.display='flex'"
                  class="bg-gray-500 hover:bg-gray-600 py-1 px-8 font-medium rounded-full shadow transition duration-200 text-white">
            Cancel
          </button>
        </div>
      <% end %>
    <% end %>
  </div>

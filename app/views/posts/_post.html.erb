<div id="<%= dom_id post %>" class="w-full sm:w-auto px-3">
 

<div class="flex max-w-full md:max-w-5xl mx-auto">

  <h2 class="text-3xl font-bold text-white break-words overflow-hidden pb-2">
           <%= link_to @post.title, [@topic, @post], class: "hover:text-[#ababab] transition " %>
  </h2>

  <% if user_signed_in? && (current_user.admin? || current_user == @post.user) %>

 <!-- 3 dots menu -->
        <div class="ml-auto ">

    <button class="peer hover:text-[#ababab] rounded-full outline-none ml-3 ">
  <svg xmlns="http://www.w3.org/2000/svg" width="30" height="30" fill="currentColor" class="bi bi-three-dots " viewBox="0 0 16 16">
    <path d="M3 9.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3m5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3"/>
  </button>
  
  <div class="absolute right-0 sm:right-auto divide-y divide-[#2a2a2a] text-sm mt-4 opacity-0 invisible peer-focus:opacity-100 peer-focus:visible transition-all duration-200 bg-[#161616] rounded-lg shadow-[0_20px_40px_-1px_rgba(0,0,0,0.3)] w-48 z-10">
    <%= link_to "Edit Post", edit_topic_post_path(@topic, @post), 
    class: "block px-4 py-4 hover:text-[#ababab] cursor-pointer" %> 

      <%= button_to "Delete post", [@topic, @post], method: :delete, 
      class: "block w-full text-left px-4 py-4 hover:text-[#ababab] cursor-pointer",
      data: { turbo_confirm: "Are you sure?" } %>
        <% if current_user&.admin? %>
       <% if @post.pinned? %>
        <%= button_to "Unpin", unpin_topic_post_path(@topic, @post), method: :patch, 
            class: "block w-full text-left px-4 py-2 text-sm text-white hover:text-[#ababab] hover:bg-gray-800 rounded-lg" %>
      <% else %>
        <%= button_to "Pin", pin_topic_post_path(@topic, @post), method: :patch, 
            class: "block w-full text-left px-4 py-2 text-sm text-white hover:text-[#ababab] hover:bg-gray-800 rounded-lg" %>
      <% end %>
      <% end %>

  </div>
  
  </div>

  <% end %>
   
  <!-- end -->


</div>

  <div class="prose max-w-none text-l md:txt-base divide-y divide-[#2a2a2a]">
      
    <!-- Tags Display -->
    <div class="flex flex-wrap items-center gap-3 pb-4 mb-5">
      <%# strong class="text-lg font-bold whitespace-nowrap">Tags:</strong%>
    <div class="flex flex-wrap items-center gap-1">
      <% if @post.tags.any? %>
        <% @post.tags.each do |tag| %>
          <%= link_to tag.name, topic_posts_path(tag: tag.name),
                class: "bg-[#de7200] text-white px-3 rounded-md text-sm hover:bg-[#df8322]" %>
        <% end %>
      <% else %>
        <p class="text-gray-400">No tags yet</p>
      <% end %>
    </div>
    </div>

      <div class="border-padding">
        <div class="mr-1 text-sm text-gray-400 float-right flex gap-2">
              <!-- Post Metadata -->
              <span> <%= time_ago_in_words(post.created_at) %></span>
              <% if post.updated_at.present? && post.updated_at > post.created_at + 1.minute %>
              <div class=" flex flex-wrap">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pencil"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12.085 6.5l5.415 5.415l-8.793 8.792a1 1 0 0 1 -.707 .293h-4a1 1 0 0 1 -1 -1v-4a1 1 0 0 1 .293 -.707zm5.406 -2.698a3.828 3.828 0 0 1 1.716 6.405l-.292 .293l-5.415 -5.415l.293 -.292a3.83 3.83 0 0 1 3.698 -.991" />
              <span><%= time_ago_in_words(post.updated_at) %> ago</span>
              </svg>
              </div>
              <% end %>
              </div>

      <div>
      <div class="flex items-start gap-2 mb-2">
        <div class="flex-shrink-0">
          <%= render 'avatar_pfp/mashit_avatar', user: @post.user %>
        </div>
        <div>
        <div class="flex flex-wrap items-center gap-1">
          <span class="font-medium"><%= post.user.username %></span>
        <% if user_has_badges?(post.user, "Developer") %>
         <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-code-circle-2"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M17 3.34a10 10 0 1 1 -15 8.66l.005 -.324a10 10 0 0 1 14.995 -8.336m-3.658 5.22a1 1 0 0 0 -1.282 .598l-2 5.5a1 1 0 0 0 1.88 .684l2 -5.5a1 1 0 0 0 -.598 -1.282m-4.135 1.233a1 1 0 0 0 -1.414 0l-1.5 1.5a1 1 0 0 0 0 1.414l1.5 1.5a1 1 0 0 0 1.414 0l.083 -.094a1 1 0 0 0 -.083 -1.32l-.792 -.793l.792 -.793a1 1 0 0 0 0 -1.414m7 0a1 1 0 0 0 -1.414 0l-.083 .094a1 1 0 0 0 .083 1.32l.792 .793l-.792 .793a1 1 0 0 0 1.414 1.414l1.5 -1.5a1 1 0 0 0 0 -1.414z" /></svg>
        <% end %>
        <% if user_has_badges?(post.user, "Admin") %>
        <svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-shield-checkered"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M11.013 12v9.754a13 13 0 0 1 -8.733 -9.754h8.734zm9.284 3.794a13 13 0 0 1 -7.283 5.951l-.001 -9.745h8.708a12.96 12.96 0 0 1 -1.424 3.794zm-9.283 -13.268l-.001 7.474h-8.986c-.068 -1.432 .101 -2.88 .514 -4.282a1 1 0 0 1 1.005 -.717a11 11 0 0 0 7.192 -2.256l.276 -.219zm1.999 7.474v-7.453l-.09 -.073a11 11 0 0 0 7.189 2.537l.342 -.01a1 1 0 0 1 1.005 .717c.413 1.403 .582 2.85 .514 4.282h-8.96z" /></svg>
        <% end %> 
        </div>
         <div class="flex flex-row gap-2 flex-wrap">
           <% if post.user.badges.any? %>
          <% post.user.badges.each do |badge| %>
          <span class="text-sm"><%= badge.name %> </span>
          <% end %>
        <% end %>
        </div>
          <div class="post-content mt-4 hidden sm:block">
            <p class="text-gray-300">
              <%= post.body %>
            </p>
          </div>
       
      </div>
          
    </div>
          <div class="post-content mt-4 block sm:hidden">
            <p class="text-gray-300">
              <%= post.body %>
            </p>
          </div>
  </div>
 <div class="mt-5">
        <button id="comment_main_btn" onclick="toggleForm(this)" class="ml-auto flex items-center gap-1 pt-2 py-1 p-3 hover:bg-[#2a2a2a] rounded-full group">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-reply-fill" viewBox="0 0 16 16">
          <path d="M5.921 11.9 1.353 8.62a.72.72 0 0 1 0-1.238L5.921 4.1A.716.716 0 0 1 7 4.719V6c1.5 0 6 0 7 8-2.5-4.5-7-4-7-4v1.281c0 .56-.606.898-1.079.62z"/>
          </svg>

          <span>Reply</span>
        </button>

        <div id="comment_form_container" style="display: none;">
          <%= turbo_frame_tag "post_comment_form" do %>
            <%= render "comments/form", topic: @topic, post: @post, comment: @comment, parent: nil %>
          <% end %>
        </div>
      </div>
        </div>
</div>

<script>
        function toggleForm(button) {
          const container = document.getElementById('comment_form_container');
          if (container.style.display === 'none') {
            container.style.display = 'block';
            button.style.display = 'none';
          } else {
            container.style.display = 'none';
            button.style.display = 'flex';
          }
        }
        </script>
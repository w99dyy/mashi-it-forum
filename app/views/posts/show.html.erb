<% content_for :title, "Showing post" %>

  <%# div class="flex-shrink-0 bg-gray-850 p-6 bg-[#2a2a2a] rounded-md inline-block" %>



<div class="md:w-2/3 w-full ">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>
  
  <%= render 'layouts/mashit_avatar', user: @post.user %>

     <h2 class="text-3xl font-bold text-white break-words overflow-hidden">
           <%= link_to @post.title, [@topic, @post], class: "hover:text-[#ababab] transition " %>

          </h2>
  
  <%= render @post %>

    <div class="my-5 border-t border-[#2a2a2a] pt-5">
    <h2 class="text-3xl font-extrabold text-slate-900 dark:text-slate-100 tracking-tight pb-5">

    <%= turbo_frame_tag "post_#{@post.id}_comment_count" do %>
      <%= pluralize(@post.comments.count, 'comment') %>
      <% end %>
      
    </h2>

    <%= turbo_frame_tag "post_comment_form" do %>
    <%= render "comments/form", topic: @topic, post: @post, comment: @comment %>
    <% end %>

  </div>

  <hr class="my-6 border-[#2a2a2a]" />
  <%= turbo_frame_tag "post_#{@post.id}_comments" do %>
   <%= render partial: "comments/comment", collection: @post.comments %>
  <% end %>


</div>

</div>

</div>
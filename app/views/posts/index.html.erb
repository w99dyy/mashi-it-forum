<% content_for :title, @topic.title %>

<div class="posts-page px-3">
  <!-- Page Header -->
  <div class="float-right max-w-full flex flew-wrap relative">

  <% if current_user&.admin? %>

 <button class="peer hover:text-[#ababab] rounded-full outline-none ml-3">
  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-pencil-cog"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M4 20h4l10.5 -10.5a2.828 2.828 0 1 0 -4 -4l-10.5 10.5v4" /><path d="M13.5 6.5l4 4" /><path d="M17.001 19a2 2 0 1 0 4 0a2 2 0 1 0 -4 0" /><path d="M19.001 15.5v1.5" /><path d="M19.001 21v1.5" /><path d="M22.032 17.25l-1.299 .75" /><path d="M17.27 20l-1.3 .75" /><path d="M15.97 17.25l1.3 .75" /><path d="M20.733 20l1.3 .75" /></svg>
  </button>
    <div class="absolute mt-2 w-32 opacity-0 invisible peer-focus:opacity-100 peer-focus:visible hover:opacity-100 hover:visible transition-all duration-200 bg-[#161616] rounded-lg shadow-lg z-10">
     <% if @topic.pinned? %>
        <%= button_to "Unpin", unpin_topic_path(@topic), method: :patch, 
            class: "block w-full text-left px-4 py-2 text-sm text-white hover:text-[#ababab] hover:bg-gray-800 rounded-lg" %>
      <% else %>
        <%= button_to "Pin", pin_topic_path(@topic), method: :patch, 
            class: "block w-full text-left px-4 py-2 text-sm text-white hover:text-[#ababab] hover:bg-gray-800 rounded-lg" %>
      <% end %>
    </div>
  <% end %>

  <%= link_to "New Post", new_topic_post_path(@topic), class: "sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-[#ed5024] hover:bg-[#e0603c] inline-block font-medium" %>
  </div>

  <div class="mb-2 border-b border-[#2a2a2a] pb-8">
    <h1 class="text-2xl font-bold text-white mb-4"> <%= @topic.title %> Posts </h1>
    <p class="float-right text-gray-400 hidden sm:block">Activity</p>
    <p class="text-gray-400 float-right pr-5 hidden sm:block"> Comments </p>
  </div>

  <!-- Posts List -->
  <div class="posts-container divide-y divide-[#2a2a2a]">
  
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="post-card  p-2 mb-3 pb-6">

            <div class="float-left pr-5">

            <%= link_to render('avatar_pfp/mashit_avatar_sm', user: post.user), profile_path(post.user.username) %>
            </div>

            <div class="overflow-hidden">

                <!-- Post Metadata -->
          
          <div class="text-gray-400 float-right hidden sm:block">
            <div class="flex items-center gap-17">
              <span> <%= post.comments.size %> </span>
              <span> <%= time_ago_in_words(post.updated_at) %> </span>
            </div>
            </div>
        
          <!-- thumbnail -->
            <%# if post.thumbnail %>
              <%# link_to image_tag(post.thumbnail.representation(resize_to_limit: [100, 100])), topic_post_path(@topic, post), class: "float-left pr-5" %>
            <%# end %>

              
          
          <!-- Post Title -->
        <div class="flex flex-wrap">
          <h2 class="text-sm sm:text-base md:text-lg font-bold mb-3">
           <%= link_to truncate(post.title, length: 100), topic_post_path(@topic, post), class: "hover:text-[#ababab] transition" %>

          </h2>
        <% if post.pinned? %>
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pinned"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 3a1 1 0 0 1 .117 1.993l-.117 .007v4.764l1.894 3.789a1 1 0 0 1 .1 .331l.006 .116v2a1 1 0 0 1 -.883 .993l-.117 .007h-4v4a1 1 0 0 1 -1.993 .117l-.007 -.117v-4h-4a1 1 0 0 1 -.993 -.883l-.007 -.117v-2a1 1 0 0 1 .06 -.34l.046 -.107l1.894 -3.791v-4.762a1 1 0 0 1 -.117 -1.993l.117 -.007h8z" /></svg>
        <% end %>
        </div>
        
          <!-- Tags -->

          <% if post.tags.any? %>
            <div class="tags">
              <div class="flex flex-wrap gap-2">
                <% post.tags.each do |tag| %>
                 <%= link_to tag.name, topic_posts_path(tag: tag.name),
                class: "bg-[#de7200] text-white px-4 rounded-full text-sm hover:bg-[#df8322]" %>

                <% end %>
            
              </div>
            </div>
          <% end %>

        
  </div>
            
          </div>
        <% end %>
      <% else %>
      
      <!-- Empty State -->
    
      <div class="empty-state text-center py-16 rounded-lg">
        <h3 class="text-2xl font-bold text-white mb-2">No posts yet</h3>
        <p class="text-gray-400 mb-6">There are no posts in this topic yet.</p>
        <%= link_to "Create Post", new_topic_post_path, 
            class: "bg-[#ed5024] hover:bg-[#e0603c] text-white px-6 py-3 rounded-lg font-semibold transition" %>
      </div>
    <% end %>
  </div>
</div>
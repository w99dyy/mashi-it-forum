<% content_for :title, @topic.title %>

  <div class="min-h-screen mx-auto px-2 md:px-0 md:w-5/6">
    <%# Page Header %>
    <div class="mb-2 border-b border-[#2a2a2a] pb-3">
      <div class="flex sm:hidden flex-col gap-3">
      <h1 class="text-xl font-bold break-words">
        <%= @topic.title %>
        <% if @topic.pinned? %>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pinned inline-block align-middle" style="color: green"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 3a1 1 0 0 1 .117 1.993l-.117 .007v4.764l1.894 3.789a1 1 0 0 1 .1 .331l.006 .116v2a1 1 0 0 1 -.883 .993l-.117 .007h-4v4a1 1 0 0 1 -1.993 .117l-.007 -.117v-4h-4a1 1 0 0 1 -.993 -.883l-.007 -.117v-2a1 1 0 0 1 .06 -.34l.046 -.107l1.894 -3.791v-4.762a1 1 0 0 1 -.117 -1.993l.117 -.007h8z" /></svg>
        <% end %>
          <% if @topic.locked? %>
              <span class="inline-block align-middle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-lock" style="color: gray";><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 2a5 5 0 0 1 5 5v3a3 3 0 0 1 3 3v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-6a3 3 0 0 1 3 -3v-3a5 5 0 0 1 5 -5m0 12a2 2 0 0 0 -1.995 1.85l-.005 .15a2 2 0 1 0 2 -2m0 -10a3 3 0 0 0 -3 3v3h6v-3a3 3 0 0 0 -3 -3" /></svg>
            </span>
          <% end %>
    </h1>
  </div>

  <%# New post for Mobile %>
  <div class="fixed bottom-6 right-6 sm:hidden z-50">
    <%= link_to new_topic_post_path(@topic), 
        class: "bg-[#ed5024] hover:bg-[#e0603c] text-white rounded-full p-4 shadow-lg flex items-center justify-center" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="12" y1="5" x2="12" y2="19"></line>
        <line x1="5" y1="12" x2="19" y2="12"></line>
      </svg>
    <% end %>
  </div>
  <div class="hidden sm:flex justify-between items-center">
    <div class="flex-1 min-w-0 items-center gap-3">
      <h1 class="text-2xl font-bold break-words overflow-hidden"><%= @topic.title %>
        <% if @topic.pinned? %>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pinned inline-block align-middle" style="color: green"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 3a1 1 0 0 1 .117 1.993l-.117 .007v4.764l1.894 3.789a1 1 0 0 1 .1 .331l.006 .116v2a1 1 0 0 1 -.883 .993l-.117 .007h-4v4a1 1 0 0 1 -1.993 .117l-.007 -.117v-4h-4a1 1 0 0 1 -.993 -.883l-.007 -.117v-2a1 1 0 0 1 .06 -.34l.046 -.107l1.894 -3.791v-4.762a1 1 0 0 1 -.117 -1.993l.117 -.007h8z" /></svg>
        <% end %>
      <% if @topic.locked? %>
              <span class="inline-block align-middle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-lock" style="color: gray";><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 2a5 5 0 0 1 5 5v3a3 3 0 0 1 3 3v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-6a3 3 0 0 1 3 -3v-3a5 5 0 0 1 5 -5m0 12a2 2 0 0 0 -1.995 1.85l-.005 .15a2 2 0 1 0 2 -2m0 -10a3 3 0 0 0 -3 3v3h6v-3a3 3 0 0 0 -3 -3" /></svg>
            </span>
          <% end %>
      </h1>
    </div>
    
    <div class="flex items-center gap-3">
          <%= link_to new_topic_post_path(@topic), class: "rounded-md px-3 py-1 bg-[#ed5024] hover:bg-[#e0603c] font-medium flex items-center gap-1" do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-plus"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 5l0 14" /><path d="M5 12l14 0" /></svg>
          <span>New post</span>
          <% end %>

      <p class="text-gray-400">Comments</p>
      <p class="text-gray-400">Activity</p>
    </div>
    </div>
  </div>

  <%# Posts list %>
  <div class="posts-container">
  
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <div class="post-card bg-[#1a1a1a] rounded-md p-2 mb-3 pb-4 <%= 'bg-orange-500/10' if post.pinned? %>">

            <div class="float-left">

            <%= link_to render('avatar_pfp/mashit_avatar_sm', user: post.user), profile_path(post.user) %>
            </div>

        <div class="overflow-hidden">
        <div class="text-gray-400 float-right hidden sm:block">
          <div class="flex items-center">
            <div class="min-w-[2.5rem] text-center tabular-nums">
              <%= post.comments.size %>
            </div>
            
            <div class="min-w-[5rem] text-right tabular-nums">
              <%= time_ago_in_words(post.updated_at) %>
            </div>
            <%=  %>
          </div>
        </div>
        
          <%# thumbnail %>
            <%# if post.thumbnail %>
              <%# link_to image_tag(post.thumbnail.representation(resize_to_limit: [100, 100])), topic_post_path(@topic, post), class: "float-left pr-5" %>
            <%# end %>

              
          
          <%# Post title %>
        <div class="flex flex-wrap items-center mb-2">
          <h2 class="text-md sm:text-base md:text-lg font-bold">
           <%= link_to truncate(post.title, length: 70), topic_post_path(@topic, post), class: "hover:text-[#ababab] transition" %>
           <span>
          <% if post.pinned? %>
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-pinned inline-block align-middle" style="color: green"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M16 3a1 1 0 0 1 .117 1.993l-.117 .007v4.764l1.894 3.789a1 1 0 0 1 .1 .331l.006 .116v2a1 1 0 0 1 -.883 .993l-.117 .007h-4v4a1 1 0 0 1 -1.993 .117l-.007 -.117v-4h-4a1 1 0 0 1 -.993 -.883l-.007 -.117v-2a1 1 0 0 1 .06 -.34l.046 -.107l1.894 -3.791v-4.762a1 1 0 0 1 -.117 -1.993l.117 -.007h8z" /></svg>
        <% end %>
        <% if post.locked?%>
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="icon icon-tabler icons-tabler-filled icon-tabler-lock inline-block align-middle" style="color: gray"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M12 2a5 5 0 0 1 5 5v3a3 3 0 0 1 3 3v6a3 3 0 0 1 -3 3h-10a3 3 0 0 1 -3 -3v-6a3 3 0 0 1 3 -3v-3a5 5 0 0 1 5 -5m0 12a2 2 0 0 0 -1.995 1.85l-.005 .15a2 2 0 1 0 2 -2m0 -10a3 3 0 0 0 -3 3v3h6v-3a3 3 0 0 0 -3 -3" /></svg>
        <% end %>

           </span>
          </h2>
        </div>

          <%# Tags %>

          <% if post.tags.any? %>
            <div class="tags">
              <div class="flex flex-wrap gap-2">
                <% post.tags.each do |tag| %>
                 <%= link_to tag.name, topic_posts_path(tag: tag.name),
                class: "bg-[#de7200] px-3 py-0.5 rounded-full text-sm hover:bg-[#df8322]" %>

                <% end %>
            
              </div>
            </div>
          <% end %>

        
  </div>
            
          </div>
        <% end %>
      <% else %>
      
      <%# Empty State %>
    
      <div class="empty-state text-center py-16 rounded-lg">
        <h3 class="text-2xl font-bold text-white mb-2">No posts yet</h3>
        <p class="text-gray-400 mb-6">There are no posts in this topic yet.</p>
        <%= link_to "Create Post", new_topic_post_path, 
            class: "bg-[#ed5024] hover:bg-[#e0603c] text-white px-6 py-3 rounded-lg font-semibold transition" %>
      </div>
    <% end %>

    <div>
    <%= paginate @posts %>
    </div>
  </div>
</div>
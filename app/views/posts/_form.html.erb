<%= form_with(model: [@topic, @post], class: "contents") do |form| %>
  <% if post.errors.any? %>
    <div id="error_explanation" class="bg-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h2>

      <ul class="list-disc ml-6">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
      <%= form.text_field :title,
        required: true,
        minlength: 5,
        class: "w-full px-3 py-2 text-white border border-[#2a2a2a] rounded-md outline-none", 
        placeholder: "Enter a title for your post" %>
  </div>

  <!-- Tags field -->
<div class="field mb-4 text-white container mx-auto">
  <%= form.label :tag_list, "Tags", class: "text-xl font-bold text-white block pb-2 pt-5 pl-2" %>
  <%= form.text_field :tag_list, 
        class: "w-full px-3 py-2 text-white border border-[#2a2a2a] rounded-md outline-none" %>
  <p class="text-gray-400 text-sm pl-2 pt-1">Separate tags with commas ,</p>
</div>

  <div class="field mb-4 container mx-auto">
      <%= form.rich_text_area :body, class: "border border-[#2a2a2a] rounded-md outline-none",
      placeholder: "Write your post content here... You can use markdown for formatting." %>
    </div>


  <div class="inline">
    <%= form.submit class: "max-w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-[#ed5024] hover:bg-[#e0603c] text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>

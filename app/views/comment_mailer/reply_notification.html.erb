<p style="margin: 0 0 20px 0; font-size: 16px; color: #333333; text-align: center;">
Hi <%= @recipient.username %>,
</p>

<p style="margin: 0 0 20px 0; font-size: 16px; color: #333333; text-align: center;">
<strong><%= @comment.user.username %></strong> replied to your comment on
<strong><%= @post.title %></strong>:
</p>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation">
  <tr>
    <td align="center" style="padding: 0 20px;">
      <p style="margin: 0 0 20px 0; font-size: 16px; color: #333333; text-align: center; word-wrap: break-word; display: inline-block; max-width: 100%;">
        <%= @comment.body %>
      </p>
    </td>
  </tr>
</table>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 20px 0;">
  <tr>
    <td align="center">
      <a href="<%= topic_post_url(@post.topic, @post) %>" 
         style="display: inline-block; background-color: #ed5024; color: #ffffff; font-family: sans-serif; font-size: 16px; font-weight: 500; line-height: 1.4; text-decoration: none; border-radius: 8px; padding: 12px 24px;">
        View the discussion
      </a>
    </td>
  </tr>
</table>